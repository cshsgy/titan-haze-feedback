&planetary_radiation_nml
radgasv         = 'CH4' '' '' '' '' '' '' '' '' '',
radgasi         = 'CH4' 'C2H2' 'C2H6' 'C2H4' 'HCN' '' '' '' '' '',
ciapairv        = '' '' '' '' '' '' '' '' '' '',
ciapairi        = 'N2-N2' 'N2-CH4' 'CH4-CH4' 'N2-H2' '' '' '' '' '' '',
clim_gas        = '' '' '' '' '' '' '' '' '' '',
haze_data       = 'presc',
haze_clim_file  = ''
haze_presc_file = 'preschaze',
presc_gas       = 'CH4' 'C2H2' 'C2H6' 'C2H4' 'HCN' 'H2' '' '' '' '',
rayleigh_file   = 'Rayleigh.txt',
sphum_gas       = ''
sma             = 9.5
bkgnd_gas       = 'N2'
